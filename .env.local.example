# Supabase (required — create project at supabase.com)
NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Supabase service role (server-side ONLY — never NEXT_PUBLIC_)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Resend (transactional email)
RESEND_API_KEY=re_xxxx

# Device trust HMAC secret — generate with: openssl rand -hex 32
DEVICE_TRUST_SECRET=

# Phase 4 — Compliance escalation route (required for automated overdue alerts)
# Generate a strong random secret: openssl rand -base64 32
# Same value must be set in Supabase pg_cron job header: x-cron-secret
CRON_SECRET=
